# [credential "https://gist.github.com"]
# 	helper = !op plugin run -- gh auth git-credential
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign  

[maintenance]
	repo = /Users/pete.keen/workspace/zenpayroll
	repo = /Users/pete.keen/workspace/web
  repo = /Users/pete.keen/guideline/app
[init]
	defaultBranch = main